# ai_trade_program — copy to ai_trade_program/.env or merge into repo-root .env

# Flask bind (optional)
# AI_TRADE_PROGRAM_HOST=127.0.0.1
# AI_TRADE_PROGRAM_PORT=5077

# Trading 212 (dedicated AI / sandbox account)
T212_ENV_AI=demo
TRADING_212_KEY_AI=
TRADING_212_SECRET_AI=

# OpenAI — scanner grader (GPT-5-nano via Responses API)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano
# AI_OPENAI_MODEL=gpt-5-nano
# AI_OPENAI_PRICE_TABLE_JSON={"gpt-5-nano":{"in":0.05,"out":0.40}}

# Master switch for background engine (1 = run scanners/monitors)
AI_TRADING_ENABLED=0

# Slot sizing (GBP)
# SLOT_CAPITAL_GBP=1000
# SLOT_COUNT=5
# GBP_USD_RATE=1.27

# News-scanner Discord feed (audit log only — does not trade)
# AI_NEWS_SCANNER_ENABLED=0
