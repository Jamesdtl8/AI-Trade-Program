# ai_trade_program — copy to ai_trade_program/.env or merge into repo-root .env

# Flask bind (optional)
# AI_TRADE_PROGRAM_HOST=127.0.0.1
# AI_TRADE_PROGRAM_PORT=5077

# Trading 212 (dedicated AI / sandbox account)
T212_ENV_AI=demo
TRADING_212_KEY_AI=
TRADING_212_SECRET_AI=

# Gemini (scoring / monitors; same key as main bot is fine)
GEMINI_API_KEY=
# GOOGLE_GENAI_API_KEY=

# Optional OpenAI (reasoning lab)
OPENAI_API_KEY=

# Master switch for background engine (1 = run scanners/monitors)
AI_TRADING_ENABLED=0

# Slot sizing (GBP)
# SLOT_CAPITAL_GBP=1000
# SLOT_COUNT=3
# GBP_USD_RATE=1.27
